# ============================================================
# Subway Surf Motion Controller — environment variables
# Copy this file to .env and adjust the values.
# All variables are OPTIONAL; defaults are shown below.
# ============================================================

# --------------- Camera ---------------
# Friendly label used in logs (no functional effect).
CAMERA_NAME=BRIO

# OpenCV device index (0 = default system camera).
CAMERA_INDEX=0

# Capture resolution.  Minimum: 320x240.
FRAME_WIDTH=640
FRAME_HEIGHT=480

# --------------- Gesture detection ---------------
# Normalised X-axis thresholds that separate LEFT / CENTER / RIGHT lanes.
# Must satisfy: 0.05 <= LEFT_BOUND < RIGHT_BOUND <= 0.95
LEFT_BOUND=0.35
RIGHT_BOUND=0.65

# MediaPipe confidence thresholds (0.1 – 1.0).
DETECTION_CONFIDENCE=0.70
PRESENCE_CONFIDENCE=0.70
TRACKING_CONFIDENCE=0.60

# Minimum milliseconds between two identical key events (80 – 1200).
ACTION_COOLDOWN_MS=220

# --------------- UI ---------------
# Title of the OpenCV preview window.
WINDOW_TITLE=Subway Surfers Motion Controller

# Exact title of the game window to auto-focus on first action.
GAME_WINDOW_TITLE=Subway Surfers

# Set to false to disable automatic game window focus.
AUTO_FOCUS_WINDOW=true

# --------------- API server ---------------
API_HOST=127.0.0.1
API_PORT=8000

# Leave empty to disable API key authentication.
API_KEY=

# Comma-separated list of allowed CORS origins.
# Use * to allow all (development only).
API_ALLOW_ORIGINS=*

# --------------- Logging ---------------
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
